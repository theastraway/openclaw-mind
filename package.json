{
  "name": "@astramindapp/openclaw-mind",
  "version": "0.2.0",
  "description": "MIND personal knowledge graph for OpenClaw \u2014 true KG, 50+ models, MINDsense emotional intelligence, life management, projects & tasks, CRM. The most complete memory plugin for AI agents.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "mind",
    "mindapp",
    "memory",
    "knowledge-graph",
    "personal-ai",
    "long-term-memory",
    "rag",
    "ai-memory",
    "emotional-intelligence",
    "mindsense",
    "crm",
    "life-management"
  ],
  "author": "Astra AI <hello@theastraway.com>",
  "homepage": "https://www.m-i-n-d.ai/openclaw",
  "repository": {
    "type": "git",
    "url": "https://github.com/theastraway/openclaw-mind.git"
  },
  "bugs": {
    "url": "https://github.com/theastraway/openclaw-mind/issues"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.28",
      "minGatewayVersion": ">=2026.3.28"
    },
    "build": {
      "openclawVersion": "2026.4.1",
      "pluginSdkVersion": "2026.4.1"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.47"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.28"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "^2026.4.9",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
